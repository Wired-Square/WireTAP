{
  "name": "wiretap-ui",
  "private": true,
  "version": "0.6.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "bash scripts/tauri-dev.sh",
    "tauri:build": "node scripts/bump-version.js && if [ \"$APPLE_NOTARISE\" = \"true\" ]; then export APPLE_PASSWORD=\"$APPLE_NOTARY_PASSWORD\"; fi && tauri build",
    "tauri:build:debug": "tauri build --debug",
    "ios:init": "tauri ios init",
    "ios:dev": "bash scripts/ios-dev.sh",
    "ios:build": "tauri ios build",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:rebuild": "node scripts/release.js rebuild",
    "notarise:build": "APPLE_PASSWORD=\"$APPLE_NOTARY_PASSWORD\" tauri build",
    "notarise:history": "xcrun notarytool history --apple-id \"$APPLE_ID\" --team-id \"$APPLE_TEAM_ID\" --password \"$APPLE_NOTARY_PASSWORD\"",
    "notarise:log": "xcrun notarytool log --apple-id \"$APPLE_ID\" --team-id \"$APPLE_TEAM_ID\" --password \"$APPLE_NOTARY_PASSWORD\"",
    "notarise:info": "xcrun notarytool info --apple-id \"$APPLE_ID\" --team-id \"$APPLE_TEAM_ID\" --password \"$APPLE_NOTARY_PASSWORD\""
  },
  "dependencies": {
    "@fontsource/dseg7": "^4.5.4",
    "@fontsource/ubuntu": "^5.2.8",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@saurl/tauri-plugin-safe-area-insets-css-api": "^0.1.0",
    "@sentry/react": "^10.39.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-store": "^2.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "decimal.js-light": "^2.5.1",
    "dockview-react": "^4.13.1",
    "i18next": "^26.0.8",
    "lucide-react": "^0.561.0",
    "react": "^19.1.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^2.2.2",
    "react-i18next": "^17.0.6",
    "smol-toml": "^1.5.2",
    "tauri-plugin-keep-screen-on-api": "^0.1.4",
    "uplot": "^1.6.32",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.15"
  }
}
