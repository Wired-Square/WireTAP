# Copy to .env beside docker-compose.yml and edit. Never commit .env.

# Postgres superuser password (compose-internal; the DB isn't published)
POSTGRES_PASSWORD=change-me

# Break-glass admin API key — always valid, can't be revoked from the admin UI.
# Generate with: openssl rand -hex 32
WIRETAP_ADMIN_KEY=change-me

# Where the Postgres data lives on the host. Use a dedicated dataset so it can
# be snapshotted independently. TrueNAS example: /mnt/main-ssd/wiretap
WIRETAP_DATA=./data

# Prebuilt backend image tag (see deploy/README.md for how to build/distribute)
WIRETAP_IMAGE=wiretap-backend:latest

# Published ports (change if they clash with other apps on the host)
# WIRETAP_HTTP_PORT=8423
# WIRETAP_INGEST_PORT=9323

# WIRETAP_DEFAULT_DB=wiretap
# WIRETAP_AUTO_CREATE=true
