# Copy to .env and edit. Never commit .env.

# Postgres superuser password (used only inside the compose network)
POSTGRES_PASSWORD=change-me

# Break-glass admin API key — always honoured, cannot be revoked from the
# admin UI. Generate with: openssl rand -hex 32
WIRETAP_ADMIN_KEY=change-me

# Default capture database (created on first start; also hosts API keys)
WIRETAP_DEFAULT_DB=wiretap

# Allow ingest clients / imports to auto-create unknown capture databases
WIRETAP_AUTO_CREATE=true

# RUST_LOG=wiretap_backend=debug
