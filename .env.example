# Sentry error tracking (optional - Sentry is disabled when VITE_SENTRY_DSN is not set)
VITE_SENTRY_DSN=

# Sentry source map upload (build-time only, not bundled into the app)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Apple
APPLE_TEAM_ID=

# macOS code signing and notarisation (required for distributable builds)
APPLE_NOTARISE=false
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_NOTARY_PASSWORD=
